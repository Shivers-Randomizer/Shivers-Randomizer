<Window x:Class="Shivers_Randomizer.TwitchIntegrationSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:Shivers_Randomizer"
        mc:Ignorable="d" 
        Height="450" Width="400" Background="#FF333333"
        MinHeight="450" MinWidth="400"
        Title="Twitch Integration Settings">

    <TabControl Margin="10">

        <!-- General -->
        <TabItem Header="General">
            <StackPanel Orientation="Horizontal" Margin="10" VerticalAlignment="Top">
                <Label Content="Points Per Minute:" VerticalAlignment="Center" Width="110"/>
                <TextBox x:Name="txtPointsPerMinute" Width="100" 
                 TextChanged="txtPointsPerMinute_TextChanged" 
                 PreviewTextInput="NumberOnly"
                 />
            </StackPanel>
        </TabItem>

        <!-- Teleports -->
        <TabItem Header="Teleports">
            <DataGrid x:Name="dgTeleports" AutoGenerateColumns="False" CanUserAddRows="False"
              HorizontalAlignment="Left" Width="250" 
              HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" IsReadOnly="True" Width="150"/>
                    <DataGridTextColumn Header="Cost" Binding="{Binding Cost, UpdateSourceTrigger=PropertyChanged}" Width="80">
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <EventSetter Event="PreviewTextInput" Handler="NumberOnly"/>
                                <EventSetter Event="PreviewKeyDown" Handler="BlockSpace"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>

        <!-- Puzzles -->
        <TabItem Header="Puzzles">
            <DataGrid x:Name="dgPuzzles" AutoGenerateColumns="False" CanUserAddRows="False"
              HorizontalAlignment="Left" Width="250" HeadersVisibility="Column" Margin="10,0,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Puzzle" Binding="{Binding Name}" IsReadOnly="True" Width="150"/>
                    <DataGridTextColumn Header="Cost" Binding="{Binding Cost, UpdateSourceTrigger=PropertyChanged}" Width="80">
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <EventSetter Event="PreviewTextInput" Handler="NumberOnly"/>
                                <EventSetter Event="PreviewKeyDown" Handler="BlockSpace"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>

        <!-- Ixupi -->
        <TabItem Header="Ixupi">
            <DataGrid x:Name="dgIxupi" AutoGenerateColumns="False" CanUserAddRows="False"
              HorizontalAlignment="Left" Width="250" HeadersVisibility="Column" Margin="10,0,0,0"
              ColumnWidth="SizeToHeader">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" IsReadOnly="True" Width="150"/>
                    <DataGridTextColumn Header="Cost" Binding="{Binding Cost, UpdateSourceTrigger=PropertyChanged}" Width="80">
                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <EventSetter Event="PreviewTextInput" Handler="NumberOnly"/>
                                <EventSetter Event="PreviewKeyDown" Handler="BlockSpace"/>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </TabItem>

    </TabControl>
</Window>